---
const path = Astro.url.pathname;
---

<header class="site-header shell">
  <a class="wordmark" href="/" aria-label="回到首頁">WILL CHENG</a>
  <div class="header-actions">
    <nav class="site-nav" aria-label="主要導覽">
      <a class:list={{ active: path.startsWith('/writing') || path.startsWith('/posts') }} href="/writing">寫作</a>
      <a class:list={{ active: path.startsWith('/series') }} href="/series">系列</a>
      <a class:list={{ active: path.startsWith('/about') }} href="/about">關於</a>
    </nav>
    <button class="theme-toggle" data-theme-toggle type="button" aria-pressed="false" aria-label="切換為暗色模式">
      <svg class="theme-icon theme-icon-sun" viewBox="0 0 24 24" aria-hidden="true">
        <circle cx="12" cy="12" r="4"></circle>
        <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"></path>
      </svg>
      <svg class="theme-icon theme-icon-moon" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M20.5 15.5A8.5 8.5 0 0 1 8.5 3.5 8.5 8.5 0 1 0 20.5 15.5Z"></path>
      </svg>
    </button>
  </div>
</header>
