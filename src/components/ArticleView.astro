---
import type { Post } from '../lib/content';
import { formatDate, getPostSeries, postHref, readingTime } from '../lib/content';
import ArticleToc, { type TocItem } from './ArticleToc';
import { ArrowLeft, ArrowRight, ArrowUpRight } from '@lucide/astro';

interface Props {
  post: Post;
  Content: any;
  seriesPosts?: Post[];
}

const { post, Content, seriesPosts = [] } = Astro.props;
const series = getPostSeries(post);
const currentIndex = seriesPosts.findIndex((entry) => entry.id === post.id);
const previousPost = currentIndex > 0 ? seriesPosts[currentIndex - 1] : undefined;
const nextPost = currentIndex >= 0 ? seriesPosts[currentIndex + 1] : undefined;
const references = post.data.references ?? [];
const tocItems: TocItem[] = (post.body ?? '')
  .split('\n')
  .map((line) => line.match(/^##\s+(.+)$/)?.[1]?.trim())
  .filter((label): label is string => Boolean(label))
  .map((label, index) => ({ id: `section-${index + 1}`, label }));
---

<article class="article shell">
  <a class="back-link" href={series ? `/series/${series.slug}` : '/writing'}>
    <ArrowLeft aria-hidden="true" /> {series ? '回到系列' : '全部文章'}
  </a>

  {series && (
    <div class="series-context">
      <div>
        <span class="series-context-label">系列文章</span>
        <a href={`/series/${series.slug}`}>{series.title}</a>
      </div>
      <span>第 {currentIndex + 1} 篇 / {seriesPosts.length}</span>
    </div>
  )}

  <header class="article-header">
    <p class="eyebrow">{post.data.category}</p>
    <h1>{post.data.title}</h1>
    <div class="article-meta">
      <time datetime={post.data.publishedAt.toISOString()}>{formatDate(post.data.publishedAt)}</time>
      <span aria-hidden="true">·</span>
      <span>{readingTime(post)}</span>
    </div>
  </header>

  <div class="article-layout">
    <div class="prose article-prose"><Content /></div>
    <ArticleToc items={tocItems} client:load />
  </div>

  {references.length > 0 && (
    <section class="references" aria-labelledby="references-title">
      <div class="references-heading">
        <h2 id="references-title">參考資料</h2>
        <span>{references.length} 筆</span>
      </div>
      <ol class="references-list">
        {references.map((reference) => (
          <li>
            <a href={reference.url} target="_blank" rel="noreferrer">
              {reference.title} <ArrowUpRight aria-hidden="true" />
            </a>
            {reference.note && <p>{reference.note}</p>}
          </li>
        ))}
      </ol>
    </section>
  )}

  {series && (
    <nav class="series-nav" aria-label="系列文章導覽">
      {previousPost ? (
        <a href={postHref(previousPost)}>
          <span>上一篇</span>
          <strong><ArrowLeft aria-hidden="true" /> {previousPost.data.title}</strong>
        </a>
      ) : <span></span>}
      {nextPost && (
        <a class="series-next" href={postHref(nextPost)}>
          <span>下一篇</span>
          <strong>{nextPost.data.title} <ArrowRight aria-hidden="true" /></strong>
        </a>
      )}
    </nav>
  )}
</article>
