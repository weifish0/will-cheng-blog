---
import { ClientRouter } from 'astro:transitions';
import BackToTop from '../components/BackToTop.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  type?: 'website' | 'article';
  ogImage?: string;
  ogImageAlt?: string;
  publishedAt?: Date;
}

const {
  title = 'Will Cheng — 10X 加速開發',
  description = '一些個人文章、技術筆記，以及值得留下來的想法。',
  type = 'website',
  ogImage = '/og-default.png',
  ogImageAlt = 'Will Cheng Blog',
  publishedAt,
} = Astro.props;
const siteUrl = 'https://blog.will-cheng.com';
const canonical = new URL(Astro.url.pathname, siteUrl);
const ogImageUrl = new URL(ogImage, siteUrl);
---

<!doctype html>
<html lang="zh-Hant-TW">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="theme-color" content="#ffffff" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Will Cheng" />
    <meta property="og:locale" content="zh_TW" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={ogImageAlt} />
    {type === 'article' && publishedAt && (
      <meta property="article:published_time" content={publishedAt.toISOString()} />
    )}
    <link rel="canonical" href={canonical} />
    <link rel="alternate" type="application/rss+xml" title="Will Cheng RSS" href="/rss.xml" />
    <link rel="icon" href="/favicon.svg" />
    <title>{title}</title>
    <script is:inline>
      (() => {
        const themeStorageKey = 'will-cheng-theme';
        const getStoredTheme = () => {
          try {
            const storedTheme = window.localStorage.getItem(themeStorageKey);
            return storedTheme === 'dark' || storedTheme === 'light' ? storedTheme : null;
          } catch {
            return window.__willChengTheme ?? null;
          }
        };
        const applyTheme = () => {
          const storedTheme = getStoredTheme();
          const systemTheme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
          document.documentElement.dataset.theme = storedTheme ?? systemTheme;
        };

        applyTheme();
        document.addEventListener('astro:page-load', applyTheme);
      })();
    </script>
    <ClientRouter />
  </head>
  <body>
    <SiteHeader />
    <main transition:animate="fade"><slot /></main>
    <BackToTop />
    <SiteFooter />
  </body>
</html>
