---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostRow from '../components/PostRow.astro';
import SeriesRow from '../components/SeriesRow.astro';
import { getSeries, sortPosts } from '../lib/content';

const posts = sortPosts(await getCollection('posts'));
const series = getSeries(posts);
---

<BaseLayout title="寫作 — Will Cheng" description="Will Cheng 的文章、技術筆記，以及值得留下來的想法。">
  <section class="archive archive-plain shell">
    <div class="archive-list">
      <div class="section-heading">
        <h1 class="archive-title">全部文章</h1>
        <span class="muted">{posts.length} 篇</span>
      </div>
      <div class="post-list">
        {posts.map((post) => <PostRow post={post} />)}
      </div>
    </div>
  </section>

  <section class="series-preview shell" aria-labelledby="series-heading">
    <div class="section-heading">
      <h2 id="series-heading">系列文章</h2>
      <a class="text-link" href="/series">查看系列 <span aria-hidden="true">→</span></a>
    </div>
    <div class="series-list">
      {series.map((item) => <SeriesRow series={item} />)}
    </div>
  </section>
</BaseLayout>
