---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostRow from '../components/PostRow.astro';
import { sortPosts } from '../lib/content';

const posts = sortPosts(await getCollection('posts'));
const featured = posts.filter((post) => post.data.featured).slice(0, 3);
const latest = posts[0];
---

<BaseLayout>
  <section class="hero shell">
    <div class="hero-rule" aria-hidden="true"></div>
    <div class="hero-copy">
      <h1>關於建造、思考，<br />與保持好奇的筆記。</h1>
      <p>一個人的文章、技術筆記，以及值得留下來的想法。</p>
      {latest && <a class="text-link" href={`/posts/${latest.id}`}>閱讀最新文章 <span aria-hidden="true">→</span></a>}
    </div>
  </section>

  <section class="writing-preview shell" aria-labelledby="selected-writing">
    <div class="section-heading">
      <h2 id="selected-writing">精選文章</h2>
      <a class="text-link" href="/writing">查看全部 <span aria-hidden="true">→</span></a>
    </div>
    <div class="post-list">
      {featured.map((post) => <PostRow post={post} />)}
    </div>
  </section>
</BaseLayout>
