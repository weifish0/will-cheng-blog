---
import { getCollection } from 'astro:content';
import SeriesRow from '../../components/SeriesRow.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getSeries, sortPosts } from '../../lib/content';

const series = getSeries(sortPosts(await getCollection('posts')));
---

<BaseLayout title="系列文章 — Will Cheng" description="Will Cheng 按主題整理的系列文章。">
  <section class="archive archive-plain shell">
    <div class="archive-list">
      <div class="section-heading">
        <h1 class="archive-title">所有系列</h1>
        <span class="muted">{series.length} 個系列</span>
      </div>
      <div class="series-list">
        {series.map((item) => <SeriesRow series={item} />)}
      </div>
    </div>
  </section>
</BaseLayout>
