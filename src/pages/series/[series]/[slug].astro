---
import { getCollection, render } from 'astro:content';
import ArticleView from '../../../components/ArticleView.astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getSeries, postSlug, sortPosts } from '../../../lib/content';
import { getPostOgImage } from '../../../lib/og';

export const prerender = true;

export async function getStaticPaths() {
  const series = getSeries(sortPosts(await getCollection('posts')));
  return series.flatMap((item) => item.posts.map((post) => ({
    params: { series: item.slug, slug: postSlug(post) },
    props: { post, seriesPosts: item.posts },
  })));
}

const { post, seriesPosts } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout
  title={`${post.data.title} — Will Cheng`}
  description={post.data.description}
  type="article"
  ogImage={getPostOgImage(post)}
  ogImageAlt={`${post.data.title} — Will Cheng`}
  publishedAt={post.data.publishedAt}
>
  <ArticleView post={post} Content={Content} seriesPosts={seriesPosts} />
</BaseLayout>
