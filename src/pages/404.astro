---
import BaseLayout from '../layouts/BaseLayout.astro';
import { ArrowRight } from '@lucide/astro';
---

<BaseLayout title="找不到頁面 — Will Cheng">
  <section class="not-found shell">
    <p class="eyebrow">404</p>
    <h1>這一頁走遠了。</h1>
    <p>找不到你要的內容，也許它還在草稿裡。</p>
    <a class="text-link" href="/">回到首頁 <ArrowRight aria-hidden="true" /></a>
  </section>
</BaseLayout>
