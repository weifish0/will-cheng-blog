---
import { getCollection, render } from 'astro:content';
import ArticleView from '../../components/ArticleView.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { postSlug, sortPosts } from '../../lib/content';
import { getPostOgImage } from '../../lib/og';

export const prerender = true;

export async function getStaticPaths() {
  const posts = sortPosts(await getCollection('posts'))
    .filter((post) => !post.data.seriesSlug);
  return posts.map((post) => ({ params: { slug: postSlug(post) }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout
  title={`${post.data.title} — Will Cheng`}
  description={post.data.description}
  type="article"
  ogImage={getPostOgImage(post)}
  ogImageAlt={`${post.data.title} — Will Cheng`}
  publishedAt={post.data.publishedAt}
>
  <ArticleView post={post} Content={Content} />
</BaseLayout>
